configfile: "config/config.yaml"


def get_param(scenario, param):
    """Get parameter value, falling back to defaults if not specified in scenario."""
    scenario_config = config["scenarios"].get(scenario, {})
    if param in scenario_config:
        return scenario_config[param]
    return config["defaults"][param]


def get_all_outputs():
    """Generate all output files across scenarios and replicates."""
    outputs = []
    for scenario in config["scenarios"].keys():
        n_reps = get_param(scenario, "replicates")
        for rep in range(1, n_reps + 1):
            outputs.append(f"results/{scenario}/rep{rep}/pedigree.parquet")
            outputs.append(f"results/{scenario}/rep{rep}/phenotype.parquet")
            outputs.append(f"results/{scenario}/rep{rep}/validation.yaml")
    return outputs


PHENOTYPE_PLOTS = [
    "death_age_distribution.png",
    "phenotype_traits.png",
    "liability_regression.png",
    "liability_joint.png",
    "liability_violin.png",
    "cumulative_incidence.png",
    "censoring_windows.png",
    "tetrachoric_sibling.png",
]


def get_phenotype_plot_outputs():
    """Generate phenotype plot output paths across scenarios."""
    outputs = []
    for scenario in config["scenarios"].keys():
        for plot in PHENOTYPE_PLOTS:
            outputs.append(f"results/{scenario}/plots/{plot}")
    return outputs


def get_all_validations():
    """Generate all validation file paths for gather_validation."""
    validations = []
    for scenario in config["scenarios"].keys():
        n_reps = get_param(scenario, "replicates")
        for rep in range(1, n_reps + 1):
            validations.append(f"results/{scenario}/rep{rep}/validation.yaml")
    return validations


def get_weibull_outputs():
    """Generate weibull result paths for both traits across all scenarios/reps."""
    outputs = []
    for scenario in config["scenarios"].keys():
        n_reps = get_param(scenario, "replicates")
        for rep in range(1, n_reps + 1):
            for trait in [1, 2]:
                outputs.append(
                    f"results/{scenario}/rep{rep}/weibull/trait{trait}/results.rwe"
                )
    return outputs


def get_scenario_outputs(scenario):
    """Generate all output files for a single scenario."""
    n_reps = get_param(scenario, "replicates")
    outputs = []
    for rep in range(1, n_reps + 1):
        outputs.append(f"results/{scenario}/rep{rep}/pedigree.parquet")
        outputs.append(f"results/{scenario}/rep{rep}/phenotype.parquet")
        outputs.append(f"results/{scenario}/rep{rep}/validation.yaml")
        for trait in [1, 2]:
            outputs.append(
                f"results/{scenario}/rep{rep}/weibull/trait{trait}/results.rwe"
            )
    for plot in PHENOTYPE_PLOTS:
        outputs.append(f"results/{scenario}/plots/{plot}")
    return outputs


rule scenario:
    """Build all outputs for a single scenario: snakemake --cores 1 -s workflow/Snakefile results/baseline10K/scenario.done"""
    input:
        lambda w: get_scenario_outputs(w.scenario)
    output:
        touch("results/{scenario}/scenario.done")


rule all:
    input:
        get_all_outputs(),
        "results/validation_summary.tsv",
        "results/plots/variance_components.png",
        get_phenotype_plot_outputs(),
        get_weibull_outputs()


rule simulate:
    output:
        pedigree="results/{scenario}/rep{rep}/pedigree.parquet",
        params="results/{scenario}/rep{rep}/params.yaml"
    params:
        seed=lambda w: get_param(w.scenario, "seed") + int(w.rep) - 1,
        N=lambda w: get_param(w.scenario, "N"),
        G_ped=lambda w: get_param(w.scenario, "G_ped"),
        G_sim=lambda w: get_param(w.scenario, "G_sim"),
        fam_size=lambda w: get_param(w.scenario, "fam_size"),
        p_mztwin=lambda w: get_param(w.scenario, "p_mztwin"),
        p_nonsocial_father=lambda w: get_param(w.scenario, "p_nonsocial_father"),
        rep=lambda w: int(w.rep),
        A1=lambda w: get_param(w.scenario, "A1"),
        C1=lambda w: get_param(w.scenario, "C1"),
        A2=lambda w: get_param(w.scenario, "A2"),
        C2=lambda w: get_param(w.scenario, "C2"),
        rA=lambda w: get_param(w.scenario, "rA"),
        rC=lambda w: get_param(w.scenario, "rC"),
    log:
        "logs/{scenario}/rep{rep}/simulate.log"
    benchmark:
        "benchmarks/{scenario}/rep{rep}/simulate.tsv"
    resources:
        mem_mb=32000,
        runtime=60
    threads: 1
    script:
        "scripts/simulate.py"


rule phenotype:
    input:
        pedigree="results/{scenario}/rep{rep}/pedigree.parquet"
    output:
        phenotype="results/{scenario}/rep{rep}/phenotype.parquet"
    params:
        seed=lambda w: get_param(w.scenario, "seed") + int(w.rep) - 1,
        # Trait 1 phenotype parameters
        beta1=lambda w: get_param(w.scenario, "beta1"),
        rate1=lambda w: get_param(w.scenario, "rate1"),
        k1=lambda w: get_param(w.scenario, "k1"),
        # Trait 2 phenotype parameters
        beta2=lambda w: get_param(w.scenario, "beta2"),
        rate2=lambda w: get_param(w.scenario, "rate2"),
        k2=lambda w: get_param(w.scenario, "k2"),
        # Shared parameters
        standardize=lambda w: get_param(w.scenario, "standardize"),
        censor_age=lambda w: get_param(w.scenario, "censor_age"),
        death_rate=lambda w: get_param(w.scenario, "death_rate"),
        death_k=lambda w: get_param(w.scenario, "death_k"),
        young_gen_censoring=lambda w: get_param(w.scenario, "young_gen_censoring"),
        middle_gen_censoring=lambda w: get_param(w.scenario, "middle_gen_censoring"),
        old_gen_censoring=lambda w: get_param(w.scenario, "old_gen_censoring"),
        G_pheno=lambda w: get_param(w.scenario, "G_pheno"),
    log:
        "logs/{scenario}/rep{rep}/phenotype.log"
    script:
        "scripts/phenotype.py"


